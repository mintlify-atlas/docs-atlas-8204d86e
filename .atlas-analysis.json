  "keyFeatures": [
    "Admin-controlled student lifecycle with payment approval flow",
    "Multi-skill literacy assessments (reading, listening, writing, speaking)",
    "Daily skill-based learning tasks with reward points (RP) system",
    "Four literacy levels: foundational, functional, transitional, advanced",
    "Secure file uploads via Cloudflare R2 presigned URLs",
    "JWT-based authentication with separate admin and student roles",
    "Cloudflare Worker for R2 event processing and daily orphan file cleanup",
    "Full audit log for all admin actions"
  ],
  "publicApiSurface": [
    "POST /api/register",
    "POST /api/admin/login",
    "POST /api/student/login",
    "GET /api/admin/students",
    "GET /api/admin/students/[childId]",
    "GET /api/admin/payments",
