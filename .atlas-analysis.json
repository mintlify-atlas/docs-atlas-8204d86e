    "GET /api/admin/content",
    "POST /api/admin/content",
    "GET /api/admin/assessments",
    "POST /api/admin/assessments/assign-level",
    "GET /api/admin/daily-tasks",
    "POST /api/admin/daily-tasks",
    "GET /api/student/daily-tasks",
    "POST /api/student/daily-tasks/[taskId]",
    "GET /api/student/assessment",
    "POST /api/student/assessment",
    "GET /api/student/content",
    "POST /api/upload/presign",
    "POST /api/upload/confirm",
    "POST /api/internal/r2-webhook",
    "POST /api/internal/orphan-sweep"
  ]
